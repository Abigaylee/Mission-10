# Root .gitignore so we don't accidentally commit generated artifacts
# (node_modules/bin/obj). The assignment SQLite file lives under backend/Mission10/Mission10/
# and is tracked in git; ignore SQLite journal files only.

**/node_modules/
**/dist/
**/bin/
**/obj/

**/*.sqlite-wal
**/*.sqlite-shm

# VS/Editor
.vscode/
.idea/
*.suo

# Root npm lock (this repo uses frontend/package-lock.json instead)
package-lock.json

# Visual Studio / solution cache
**/.vs/
**/*.slnx
**/*.csproj.user


